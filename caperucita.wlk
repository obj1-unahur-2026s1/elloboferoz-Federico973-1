object caperucita {
    var peso = 61.2
    method perdioUnaManzana(){
        peso = peso - 0.2 
    }
    method peso() = peso
    method esComida() {
      peso = "Ingerida"
    }
    method esSalvada() {
      peso = 60
    }
    }

